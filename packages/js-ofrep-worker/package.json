{
  "name": "@openfeature/flagd-ofrep-cf-worker",
  "version": "0.1.0",
  "description": "flagd OFREP handler for Cloudflare Workers - in-process flag evaluation using the flagd evaluation engine",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "test": "echo 'No tests yet'"
  },
  "keywords": [
    "openfeature",
    "flagd",
    "ofrep",
    "cloudflare",
    "workers",
    "feature-flags",
    "feature-toggles"
  ],
  "author": "OpenFeature",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-feature/flagd-ofrep-cf-worker.git",
    "directory": "packages/js-ofrep-worker"
  },
  "dependencies": {
    "@openfeature/core": "^1.9.1",
    "@openfeature/flagd-core": "^1.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260127.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "^4.20260127.0"
  },
  "peerDependenciesMeta": {
    "@cloudflare/workers-types": {
      "optional": true
    }
  }
}
