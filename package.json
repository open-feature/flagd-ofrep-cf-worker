{
  "name": "flagd-ofrep-cf-worker",
  "version": "0.0.0",
  "private": true,
  "description": "flagd OFREP edge runtime package and examples for in-process flag evaluation",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "jest",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "dev": "npm run dev --workspace=examples/js-worker",
    "dev:cloudflare": "npm run dev --workspace=examples/js-worker",
    "dev:vercel": "npm run dev --workspace=examples/vercel-edge",
    "dev:fastly": "npm run dev --workspace=examples/fastly-compute",
    "dev:deno": "npm run dev --workspace=examples/deno-deploy",
    "deploy": "npm run deploy --workspace=examples/js-worker",
    "deploy:cloudflare": "npm run deploy --workspace=examples/js-worker",
    "deploy:vercel": "npm run deploy --workspace=examples/vercel-edge",
    "deploy:fastly": "npm run deploy --workspace=examples/fastly-compute",
    "smoke:cloudflare": "OFREP_BASE_URL=http://localhost:8787 node scripts/smokeOfrep.mjs",
    "smoke:vercel": "OFREP_BASE_URL=http://localhost:8788 node scripts/smokeOfrep.mjs",
    "smoke:fastly": "OFREP_BASE_URL=http://127.0.0.1:7676 node scripts/smokeOfrep.mjs",
    "smoke:deno": "OFREP_BASE_URL=http://localhost:8790 node scripts/smokeOfrep.mjs",
    "prepare": "husky || true"
  },
  "workspaces": [
    "packages/*",
    "examples/*",
    "contrib/js-sdk-contrib/libs/shared/flagd-core"
  ],
  "keywords": [
    "openfeature",
    "flagd",
    "ofrep",
    "edge-runtime",
    "fetch-api",
    "feature-flags"
  ],
  "author": "OpenFeature",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-feature/flagd-ofrep-cf-worker.git"
  },
  "devDependencies": {
    "@types/imurmurhash": "^0.1.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "@types/object-hash": "^3.0.6",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2"
  }
}
